{
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "rsx"
  ],
  "files.associations": {
    "*.rsx": "typescriptreact",
    "*.tsx": "typescriptreact"
  },
  "eslint.nodePath": "./node_modules"
}